# Dependencies - NEVER commit these
node_modules/
*/node_modules/
**/node_modules/

# Environment files - NEVER commit these (contain secrets)
.env
.env.local
*.env
educhain-backend/.env
educhain-frontend/.env

# Package lock files (optional - many projects commit these, but you can ignore)
# package-lock.json
# */package-lock.json
# **/package-lock.json

# Build outputs
dist/
build/
*/dist/
*/build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
